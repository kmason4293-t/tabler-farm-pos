# ════════════════════════════════════════════════
#  Tabler Farm — Environment Variables
#  Copy this file to .env and fill in your keys.
#  NEVER share or commit your .env file.
# ════════════════════════════════════════════════

# Your Stripe SECRET key — starts with sk_live_ (or sk_test_ for testing)
# Find this at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Port the server runs on (3000 is fine, change if needed)
PORT=3000
